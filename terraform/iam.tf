# EC2 Volume Operations Policy
resource "aws_iam_policy" "ec2_volume_operations" {
  name        = "${local.name}-ec2-volume-operations"
  description = "Policy for EC2 volume operations"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "VisualEditor0"
        Effect    = "Allow"
        Action    = [
          "ec2:CreateTags",
          "ec2:CreateVolume",
          "ec2:AttachVolume"
        ]
        Resource = "*"
      }
    ]
  })
}